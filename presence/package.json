{
	"name": "@absolutejs/sync-pack-presence",
	"version": "0.4.0",
	"description": "Per-channel live presence pack for @absolutejs/sync — heartbeat-driven, scoped, TTL-cleaned, with cursor + typing state patches",
	"repository": {
		"type": "git",
		"url": "https://github.com/absolutejs/sync-packs.git",
		"directory": "presence"
	},
	"homepage": "https://github.com/absolutejs/sync-packs/tree/main/presence",
	"bugs": {
		"url": "https://github.com/absolutejs/sync-packs/issues"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"license": "Apache-2.0",
	"author": "Alex Kahn",
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"absolutejs",
		"sync",
		"sync-pack",
		"presence",
		"multiplayer",
		"realtime"
	],
	"scripts": {
		"build": "rm -rf dist && bun build src/index.ts --outdir dist --sourcemap --target=bun --external @absolutejs/sync && tsc --project tsconfig.build.json",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"format": "prettier --write \"./**/*.{ts,json,md}\"",
		"release": "bun run format && bun run typecheck && bun run test && bun run build && bun publish"
	},
	"peerDependencies": {
		"@absolutejs/sync": ">= 1.9.1"
	},
	"devDependencies": {
		"@absolutejs/sync": "^1.9.2",
		"@types/bun": "1.3.14",
		"prettier": "3.5.3",
		"typescript": "5.8.3"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	]
}
